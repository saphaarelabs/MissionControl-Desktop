# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Clerk (get from clerk.com → API Keys)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Backend proxy URL (desktop/web app target)
VITE_API_BASE=https://mission-control-backend-topaz.vercel.app
VITE_CONTROL_PLANE_URL=https://mission-control-control-plane.vercel.app

# Electron desktop runtime URLs
MISSION_CONTROL_BACKEND_URL=https://mission-control-backend-topaz.vercel.app
MISSION_CONTROL_CONTROL_PLANE_URL=https://mission-control-control-plane.vercel.app

# Supabase (optional — only if any frontend component reads Supabase directly)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Backend (server/backend/index.js) ─────────────────────────────────────────
# Supabase service role (server-side only — never expose to frontend)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Clerk (for JWT verification — get from clerk.com → API Keys)
CLERK_SECRET_KEY=sk_test_...
# Or use the JWT public key for offline verification (faster, no network call):
# CLERK_JWT_KEY=-----BEGIN PUBLIC KEY-----...

# Port for the backend server (default: 4000)
PORT=4000

# Control plane (internal — for triggering user provisioning)
OPENCLAW_CONTROL_PLANE_URL=http://localhost:4445
OPENCLAW_INTERNAL_SECRET=your-internal-secret-here
